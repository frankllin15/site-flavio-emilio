# Resend API Configuration
# Obtenha sua API key em: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# Email de destino (quem recebe as mensagens do formulário)
CONTACT_EMAIL_TO=contato@flavioemilio.com.br

# Email de origem (remetente - deve ser verificado no Resend)
# Use onboarding@resend.dev para testes ou configure seu domínio no Resend
CONTACT_EMAIL_FROM=onboarding@resend.dev

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

GITHUB_PAT=